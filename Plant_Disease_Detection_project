        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# 1. Generate a \"Healthy\" Plant Signal (Pure 50Hz Sine Wave)\n",
        "fs = 1000  # Sampling frequency\n",
        "t = np.linspace(0, 1, fs)\n",
        "healthy_signal = np.sin(2 * np.pi * 50 * t)\n",
        "\n",
        "# 2. Generate a \"Diseased\" Signal (Adds High-Frequency Noise/Harmonics)\n",
        "# In EEE, we know disease changes the plant's impedance!\n",
        "noise = 0.5 * np.sin(2 * np.pi * 150 * t) # A \"Disease\" Harmonic\n",
        "diseased_signal = healthy_signal + noise + np.random.normal(0, 0.2, fs)\n",
        "\n",
        "# 3. Visualization (This is what you'll screenshot for LinkedIn)\n",
        "plt.figure(figsize=(12, 4))\n",
        "plt.subplot(1, 2, 1)\n",
        "plt.plot(t[:100], healthy_signal[:100])\n",
        "plt.title(\"Healthy Plant Signal\")\n",
        "plt.subplot(1, 2, 2)\n",
        "plt.plot(t[:100], diseased_signal[:100], color='red')\n",
        "plt.title(\"Diseased Plant Signal (High Noise)\")\n",
        "plt.show()"
      ]
    }
